{
  "extends": "./.wxt/tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    ".wxt/wxt.d.ts",
    "entrypoints/**/*",
    "src/**/*",
    "tests/**/*",
    "wxt.config.ts"
  ]
}
