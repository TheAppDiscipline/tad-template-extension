{
  "name": "tad-template-extension",
  "description": "Discipline Loop Browser Extension template (WXT + React + TS, Manifest V3, Chromium + Firefox)",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheAppDiscipline/tad-template-extension.git"
  },
  "homepage": "https://github.com/TheAppDiscipline/tad-template-extension#readme",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip && wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-tokens": "node tools/check_no_hex_colors.js",
    "check-secrets": "node tools/check_no_secrets_in_frontend.js",
    "check-https": "node tools/check_https_redirect.js",
    "check-manifest": "node tools/check_manifest.js",
    "check-bundle-extension": "node tools/check_bundle_extension.js",
    "check-extension-release": "node tools/check_extension_release_ready.js",
    "check-magic": "node tools/check_magic_numbers.js",
    "check-magic:strict": "node tools/check_magic_numbers.js --strict",
    "check-queries": "node tools/check_query_limits.js",
    "check-queries:strict": "node tools/check_query_limits.js --strict",
    "check-db-types": "node tools/check_db_types.js",
    "check-db-types:strict": "node tools/check_db_types.js --strict",
    "db:types:generate": "node tools/generate_db_types.js",
    "audit:high": "node tools/check_audit.js",
    "gate": "npm run lint && npm run compile && npm run test && npm run check-tokens && npm run check-secrets && npm run check-https && npm run build && npm run build:firefox && npm run check-manifest",
    "gate:full": "npm run gate && npm run zip && npm run check-magic && npm run check-queries && npm run check-bundle-extension",
    "gate:strict": "npm run gate && npm run check-magic:strict && npm run check-queries:strict && npm run check-db-types:strict && npm run check-extension-release",
    "gate:launch": "npm run gate:strict && npm run discipline:validate:launch && npm run audit:high",
    "discipline:hydrate": "tsx tools/discipline/hydrate-template.ts",
    "discipline:patch": "tsx tools/discipline/apply-patch.ts",
    "discipline:patch:dry-run": "tsx tools/discipline/apply-patch.ts --dry-run",
    "discipline:assemble": "tsx tools/discipline/assemble-paste-ready.ts",
    "discipline:progress": "tsx tools/discipline/update-progress.ts",
    "discipline:log": "tsx tools/discipline/log-run.ts",
    "discipline:validate": "tsx tools/discipline/validate-discipline.ts",
    "discipline:validate:launch": "tsx tools/discipline/validate-scorecard.ts --mode=launch",
    "discipline:validate:prod": "tsx tools/discipline/validate-scorecard.ts --mode=prod",
    "discipline:validate:scope": "tsx tools/discipline/validate-scope.ts",
    "discipline:validate:architecture": "tsx tools/discipline/validate-architecture.ts",
    "discipline:doctor": "tsx tools/discipline/doctor.ts",
    "discipline:release-pack": "tsx tools/discipline/release-pack.ts",
    "discipline:cross-validate": "tsx tools/discipline/cross-validate.ts",
    "discipline:cross-validate:live": "tsx tools/discipline/cross-validate.ts --live",
    "discipline:status": "tsx tools/discipline/validate-discipline.ts --status",
    "discipline:watch": "tsx tools/discipline/watch.ts",
    "discipline:step1-prep": "tsx tools/discipline/step1-prep.ts",
    "discipline:ai-scaffold": "tsx tools/discipline/ai-scaffold.ts",
    "discipline:test-scaffold": "tsx tools/discipline/test-scaffold.ts",
    "discipline:codex-batch": "tsx tools/discipline/codex-batch.ts",
    "discipline:audit-merge": "tsx tools/discipline/audit-merge.ts",
    "discipline": "tsx tools/discipline/cli.ts",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium",
    "gate:visual": "npm run build && npm run e2e"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@wxt-dev/module-react": "^1.1.0",
    "ajv": "^8.20.0",
    "eslint": "^9.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "js-yaml": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "~5.6.0",
    "vitest": "^4.1.8",
    "wxt": "^0.19.29"
  },
  "overrides": {
    "shell-quote": "1.8.4",
    "tar": "7.5.16",
    "tmp": "0.2.7",
    "uuid": "14.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
